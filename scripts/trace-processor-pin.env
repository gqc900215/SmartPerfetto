#
# Single source of truth for the trace_processor_shell prebuilt pin.
# Sourced by:
#   - scripts/start-dev.sh (local dev: prebuilt-first, source-build fallback)
#   - Dockerfile (container build)
#   - .github/workflows/backend-agent-regression-gate.yml (CI)
# Download callers may override the source with TRACE_PROCESSOR_DOWNLOAD_BASE
# (same path layout) or TRACE_PROCESSOR_DOWNLOAD_URL (exact platform URL);
# the SHA256 pins below are still enforced.
#
# Format: KEY=VALUE only (no quotes, no inline comments) so it works with
# `source` in bash AND with `cat >> $GITHUB_ENV` in GitHub Actions.
#
# Upgrade workflow (when bumping perfetto submodule, e.g. v54 -> v56):
#   1. Update PERFETTO_VERSION below.
#   2. Recompute SHA256 for all supported platforms:
#        for p in linux-amd64 linux-arm64 mac-amd64 mac-arm64; do
#          curl -fsSL "https://commondatastorage.googleapis.com/perfetto-luci-artifacts/${VERSION}/${p}/trace_processor_shell" \
#            | shasum -a 256 | awk -v p="$p" '{print p, $1}'
#        done
#        curl -fsSL "https://commondatastorage.googleapis.com/perfetto-luci-artifacts/${VERSION}/windows-amd64/trace_processor_shell.exe" \
#          | shasum -a 256 | awk '{print "windows-amd64", $1}'
#   3. Paste the new hashes below.
#   4. Run `npm run trace-processor:sync-prebuilts` to refresh committed
#      Linux x64, macOS arm64, and Windows x64 prebuilts.
#   5. Run `cd backend && npm run test:scene-trace-regression` to confirm
#      the new prebuilt binary still passes the 6 canonical traces.

PERFETTO_VERSION=v56.0
PERFETTO_LUCI_URL_BASE=https://commondatastorage.googleapis.com/perfetto-luci-artifacts

PERFETTO_SHELL_SHA256_LINUX_AMD64=2ef3c927d0eabaa246e383b221217158c189ee2c3b638de497ce913e268a34e7
PERFETTO_SHELL_SHA256_LINUX_ARM64=996eda7c304be9fe4c859b96fbe4decc1cb406281ab4db077f0c762385a6c272
PERFETTO_SHELL_SHA256_MAC_AMD64=ca38354e77f5afe3d432576a350ce8000a9b394c5d13a2b70345a53d7a453ab5
PERFETTO_SHELL_SHA256_MAC_ARM64=21a68743627c3435146f8c241f767761ed9c161341a2ad2dfef47e50aa7160d9
PERFETTO_SHELL_SHA256_WINDOWS_AMD64=3d31ecb66285cb209541f5d1e6fec5e5824cd8364f8b8b9f03af61ada1b0217c
